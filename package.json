{
    "name": "monaco-editor-demo",
    "version": "1.0.0",
    "description": "Monaco Editor 示例项目，支持 Python LSP",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "server:dev": "ts-node server/src/index.ts",
        "server:build": "tsc -p server/tsconfig.json",
        "server:start": "node server/dist/index.js",
        "mcp:editor": "ts-node server/src/mcp/editor-mcp-server.ts",
        "test": "jest --config jest.config.js",
        "test:watch": "jest --config jest.config.js --watch",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui"
    },
    "dependencies": {
        "express": "^4.18.2",
        "express-ws": "^5.0.2",
        "marked": "^18.0.3",
        "monaco-editor": "0.55.1",
        "openai": "^6.35.0",
        "pyright": "^1.1.350",
        "ws": "^8.14.2"
    },
    "devDependencies": {
        "@playwright/test": "^1.52.0",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.11",
        "@types/node": "^20.10.6",
        "@types/ws": "^8.5.10",
        "esbuild": "^0.28.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.4.9",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3",
        "vite": "^8.0.10",
        "vite-plugin-monaco-editor": "^1.1.0"
    }
}